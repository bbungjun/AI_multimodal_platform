# PostgreSQL
POSTGRES_USER=app
POSTGRES_PASSWORD=changeme
POSTGRES_DB=multimodal

# AI provider
# Use vertex for the original submitted provider path. Use mock for local
# credential-free development only.
AI_PROVIDER=vertex

# Vertex/Gemini credentials
# Do not paste service-account JSON content here. Set this to the host path of
# the JSON file; Docker Compose mounts it read-only at /secrets/sa.json.
# For local ADC (gcloud application-default login), leave
# GOOGLE_APPLICATION_CREDENTIALS unset in your real .env. The backend will use
# google-auth ADC without reading or committing JSON contents in this repo.
GOOGLE_APPLICATION_CREDENTIALS=/secrets/sa.json
GOOGLE_APPLICATION_CREDENTIALS_HOST=/absolute/path/to/service-account.json
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1
ENHANCE_MODEL=gemini-2.5-flash

# Backend runtime
DATA_DIR=/data/assets
JOB_RUNNER_CONCURRENCY=10

# Frontend runtime
# Empty VITE_API_BASE keeps browser requests same-origin so Vite can proxy
# /api and /files to the backend container.
VITE_API_BASE=
VITE_API_PROXY_TARGET=http://backend:8000
VITE_ALLOWED_HOSTS=localhost,127.0.0.1
